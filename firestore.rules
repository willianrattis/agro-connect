rules_version = '2';

// Owner-based ruleset: every collection below is scoped by an `ownerId`
// field (or, for /users and /settings, by the document id itself) that
// must match the signed-in uid, OR belong to a verified-email member of
// that owner's account (see `accounts/{ownerUid}.memberEmails`), on every
// read/write. `ownerImmutable()` blocks an update from ever reassigning a
// document to a different owner, so cross-owner access is denied both at
// creation and thereafter.
//
// Deliberately deferred / out of scope for these rules:
//   - serverTimestamp enforcement (createdAt/updatedAt aren't checked
//     against request.time) — trusted client input for now.
//   - earTag uniqueness — cross-document uniqueness isn't cheap to check
//     in rules; if/when it matters, enforce it at the app layer (e.g. a
//     lookup query before insert, or a dedicated index collection).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // A signed-in, verified-email user whose email is listed as a member
    // of `ownerId`'s account has the same access as the owner.
    function memberOf(ownerId) {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in
           get(/databases/$(database)/documents/accounts/$(ownerId)).data.memberEmails;
    }
    function canAccess(ownerId) { return signedIn() && (request.auth.uid == ownerId || memberOf(ownerId)); }

    function owns(rsc)  { return canAccess(rsc.data.ownerId); }
    function ownsNew()  { return canAccess(request.resource.data.ownerId); }
    function ownerImmutable() { return request.resource.data.ownerId == resource.data.ownerId; }

    // Profile & per-user settings: keyed by uid (no ownerId field — the
    // document id itself is the ownership boundary).
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    match /settings/{uid} {
      allow read, write: if canAccess(uid);
    }

    // Shared-account membership: accountId is always the owner's uid.
    // Owner manages membership; members (and the owner) can read it to
    // discover their own access.
    match /accounts/{accountId} {
      allow read:   if signedIn()
                    && (request.auth.uid == accountId
                        || (request.auth.token.email_verified == true
                            && request.auth.token.email.lower() in resource.data.memberEmails));
      allow create: if request.auth.uid == accountId
                    && request.resource.data.ownerId == accountId
                    && request.resource.data.memberEmails is list;
      allow update: if request.auth.uid == accountId
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.memberEmails is list;
      allow delete: if request.auth.uid == accountId;
    }

    // Animals — always created as an optional tagged subset of a lot (the
    // lot-centric "Novo lote" flow), so sex/category/lotId/propertyId are
    // as required on create as earTag.
    match /animals/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.earTag is string
                    && request.resource.data.earTag.size() > 0
                    && request.resource.data.sex in ["M", "F"]
                    && request.resource.data.category is string
                    && request.resource.data.category.size() > 0
                    && request.resource.data.lotId is string
                    && request.resource.data.propertyId is string;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lots — every lot is created through the unified lot-centric flow, so
    // it always carries a property, sex, a taxonomy entry category, an
    // origin and a positive headcount (the source of truth for lot size;
    // tagged animals are an optional subset and never affect it).
    match /lots/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.propertyId is string
                    && request.resource.data.propertyId.size() > 0
                    && request.resource.data.sex in ["M", "F"]
                    && request.resource.data.entryCategory is string
                    && request.resource.data.entryCategory.size() > 0
                    && request.resource.data.origin in ["purchased", "born"]
                    && request.resource.data.headcount is int
                    && request.resource.data.headcount > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lifecycle events — type is a closed set so a typo can't silently
    // create an event no KPI/history query will ever match.
    match /events/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.type in [
                         "purchase", "sale", "weighing", "death",
                         "weaning", "calving", "finishing",
                         "birth", "breeding", "pregnancy_check"
                       ]
                    && request.resource.data.date is timestamp;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Financial transactions
    match /transactions/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.kind in ["receita", "despesa"]
                    && request.resource.data.category is string
                    && request.resource.data.amountBRL is number
                    && request.resource.data.date is timestamp;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Properties
    match /properties/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Suppliers (produtores) — municipio/estado are optional strings, set
    // when a supplier is created from the lot-purchase seller block.
    match /suppliers/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && (!("municipio" in request.resource.data)
                        || request.resource.data.municipio == null
                        || request.resource.data.municipio is string)
                    && (!("estado" in request.resource.data)
                        || request.resource.data.estado == null
                        || request.resource.data.estado is string);
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Confinamentos (third-party feedlots) — a lot's cattle sent here stay
    // owned by the same owner, so only name/nameLower are required, same as
    // suppliers' minimal identity fields.
    match /confinements/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lot movements (aggregate-lot ledger: entries/exits, headcount deltas;
    // also property-transfer log entries)
    match /movements/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.type is string
                    && request.resource.data.lotId is string
                    && request.resource.data.date is timestamp
                    && request.resource.data.qty is number;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Bulk lot weighing sessions (avg weight + optional individual samples)
    match /lot_weighings/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.lotId is string
                    && request.resource.data.lotId.size() > 0
                    && request.resource.data.date is timestamp
                    && request.resource.data.avgWeightKg is number
                    && request.resource.data.avgWeightKg > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Everything else is denied by default (Firestore has no implicit
    // grants), stated explicitly here for auditability.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
