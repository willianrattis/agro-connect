rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function owns(rsc)  { return signedIn() && rsc.data.ownerId == request.auth.uid; }
    function ownsNew()  { return signedIn() && request.resource.data.ownerId == request.auth.uid; }
    function ownerImmutable() { return request.resource.data.ownerId == resource.data.ownerId; }

    // Profile & per-user settings: keyed by uid
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    match /settings/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Animals
    match /animals/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.earTag is string
                    && request.resource.data.earTag.size() > 0
                    && request.resource.data.category is string;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lots — every lot is now created through the unified lot-centric flow,
    // so it always carries a property, an origin and a positive headcount
    // (the source of truth for lot size; tagged animals are an optional
    // subset and never affect it).
    match /lots/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew() && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.propertyId is string
                    && request.resource.data.propertyId.size() > 0
                    && request.resource.data.origin in ["purchased", "born"]
                    && request.resource.data.headcount is int
                    && request.resource.data.headcount > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lifecycle events
    match /events/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.type is string
                    && request.resource.data.date is timestamp;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Financial transactions
    match /transactions/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew()
                    && request.resource.data.kind in ["receita", "despesa"]
                    && request.resource.data.category is string
                    && request.resource.data.amountBRL is number
                    && request.resource.data.date is timestamp;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Properties
    match /properties/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew() && request.resource.data.name is string
                    && request.resource.data.name.size() > 0;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Suppliers (produtores) — municipio/estado are optional strings, set
    // when a supplier is created from the lot-purchase seller block.
    match /suppliers/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew() && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && (!("municipio" in request.resource.data)
                        || request.resource.data.municipio == null
                        || request.resource.data.municipio is string)
                    && (!("estado" in request.resource.data)
                        || request.resource.data.estado == null
                        || request.resource.data.estado is string);
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }

    // Lot movements (aggregate-lot ledger: entries/exits, headcount deltas)
    match /movements/{id} {
      allow read:   if owns(resource);
      allow create: if ownsNew() && request.resource.data.lotId is string
                    && request.resource.data.date is timestamp
                    && request.resource.data.qty is number;
      allow update: if owns(resource) && ownsNew() && ownerImmutable();
      allow delete: if owns(resource);
    }
  }
}
